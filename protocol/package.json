{
  "name": "@mosaic/protocol-validation",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "npm run validate && npm test",
    "generate:browser-contract": "node tools/generate-browser-contract.mjs",
    "generate:preview-fixtures": "node tools/generate-local-preview-fixtures.mjs",
    "generate:preview-v0.2-contract": "node tools/generate-local-preview-v0.2-contract.mjs",
    "generate:v0.2-fixtures": "node tools/generate-v0.2-fixtures.mjs",
    "generate": "npm run generate:preview-fixtures && npm run generate:v0.2-fixtures && npm run generate:preview-v0.2-contract && npm run generate:browser-contract",
    "test": "node --test tools/*.test.mjs",
    "validate": "node tools/validate.mjs"
  },
  "dependencies": {
    "ajv": "8.20.0"
  },
  "engines": {
    "node": ">=20"
  }
}
