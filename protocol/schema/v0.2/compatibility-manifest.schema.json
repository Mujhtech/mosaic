{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mosaic:protocol:schema:v0.2:compatibility-manifest",
  "title": "Mosaic Protocol 0.2 Compatibility Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "status",
    "releaseCandidate",
    "schema",
    "canonicalFixture",
    "capabilities",
    "readerPolicy",
    "normalizedOutcomes"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "0.2"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "releaseCandidate",
        "approved",
        "deprecated"
      ]
    },
    "releaseCandidate": {
      "type": "string",
      "const": "RC4"
    },
    "schema": {
      "type": "string",
      "const": "../schema/v0.2/paywall.schema.json"
    },
    "canonicalFixture": {
      "type": "string",
      "const": "../fixtures/v0.2/complete-paywall.json"
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/capability"
      }
    },
    "readerPolicy": {
      "$ref": "#/$defs/readerPolicy"
    },
    "normalizedOutcomes": {
      "$ref": "#/$defs/normalizedOutcomes"
    }
  },
  "$defs": {
    "capabilityName": {
      "type": "string",
      "enum": [
        "layout.scrollContainer",
        "layout.stack",
        "layout.sizing",
        "layout.heightSizing",
        "layout.outerInsets",
        "navigation.screens",
        "navigation.sheets",
        "component.text",
        "component.image",
        "component.icon",
        "component.featureList",
        "component.productSelector",
        "component.productCard",
        "component.productBadge",
        "component.button",
        "component.carousel",
        "component.switch",
        "component.countdown",
        "localization.catalogs",
        "localization.rtl",
        "localization.productTemplate",
        "product.references",
        "asset.bundledImage",
        "asset.remoteImage",
        "asset.bundledVideo",
        "asset.remoteVideo",
        "action.purchase",
        "action.restore",
        "action.close",
        "action.navigateTo",
        "action.navigateBack",
        "action.openExternalUrl",
        "accessibility.metadata",
        "fallback.asset",
        "fallback.product",
        "outcome.normalized",
        "style.colors",
        "style.designTokens",
        "style.gradientBackground",
        "style.mediaBackground",
        "style.shadow",
        "style.box",
        "style.clipping",
        "style.typography",
        "style.productCardStates",
        "visibility.static",
        "condition.switchVisibility"
      ]
    },
    "capability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version",
        "fallback"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/capabilityName"
        },
        "version": {
          "type": "string",
          "const": "0.2"
        },
        "fallback": {
          "type": "string",
          "const": "rejectDocument"
        }
      }
    },
    "readerPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "unknownSchemaVersion",
        "unknownComponent",
        "unknownProperty",
        "unsupportedCapability",
        "invalidReference",
        "primaryDocumentRejected",
        "bundledFallbackRejected",
        "missingAsset",
        "missingMediaBackground",
        "fillInUnboundedAxis",
        "unavailableProduct",
        "missingProductPrice",
        "noAvailableProductCards",
        "invalidProductTemplate",
        "falseVisibilityCondition",
        "completedCountdown",
        "navigateBackWithoutHistory",
        "externalUrlOpenFailure"
      ],
      "properties": {
        "unknownSchemaVersion": {
          "const": "rejectDocument"
        },
        "unknownComponent": {
          "const": "rejectDocument"
        },
        "unknownProperty": {
          "const": "rejectDocument"
        },
        "unsupportedCapability": {
          "const": "rejectDocument"
        },
        "invalidReference": {
          "const": "rejectDocument"
        },
        "primaryDocumentRejected": {
          "const": "loadBundledFallback"
        },
        "bundledFallbackRejected": {
          "const": "configurationUnavailable"
        },
        "missingAsset": {
          "const": "useDeclaredAssetFallback"
        },
        "missingMediaBackground": {
          "const": "usePosterThenFallbackColorAndDiagnose"
        },
        "fillInUnboundedAxis": {
          "const": "useFitAndDiagnose"
        },
        "unavailableProduct": {
          "const": "useSelectorFallback"
        },
        "missingProductPrice": {
          "const": "markCardUnavailable"
        },
        "noAvailableProductCards": {
          "const": "showSelectorFallbackAndDisablePurchase"
        },
        "invalidProductTemplate": {
          "const": "rejectDocument"
        },
        "falseVisibilityCondition": {
          "const": "removeFromLayoutAccessibilityAndFocus"
        },
        "completedCountdown": {
          "const": "showLocalizedCompletedText"
        },
        "navigateBackWithoutHistory": {
          "const": "noOpAndDiagnose"
        },
        "externalUrlOpenFailure": {
          "const": "remainAndDiagnose"
        }
      }
    },
    "normalizedOutcomes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "selectProduct",
        "purchase",
        "restore",
        "close",
        "presentation"
      ],
      "properties": {
        "selectProduct": {
          "const": [
            "productSelected"
          ]
        },
        "purchase": {
          "const": [
            "purchased",
            "alreadyEntitled",
            "cancelled",
            "productUnavailable",
            "purchaseFailed"
          ]
        },
        "restore": {
          "const": [
            "restored",
            "alreadyEntitled",
            "restoreNoPurchases",
            "restoreFailed"
          ]
        },
        "close": {
          "const": [
            "dismissed"
          ]
        },
        "presentation": {
          "const": [
            "purchased",
            "restored",
            "alreadyEntitled",
            "dismissed",
            "cancelled",
            "productUnavailable",
            "configurationUnavailable",
            "purchaseFailed",
            "renderingFailed"
          ]
        }
      }
    }
  }
}
