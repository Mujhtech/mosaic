{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mosaic:protocol:schema:v0.1:compatibility-manifest",
  "title": "Mosaic Protocol 0.1 Compatibility Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "status",
    "releaseCandidate",
    "schema",
    "canonicalFixture",
    "capabilities",
    "readerPolicy",
    "normalizedOutcomes"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "0.1"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "releaseCandidate",
        "approved",
        "deprecated"
      ]
    },
    "releaseCandidate": {
      "type": "string",
      "const": "RC1"
    },
    "schema": {
      "type": "string",
      "const": "../schema/v0.1/paywall.schema.json"
    },
    "canonicalFixture": {
      "type": "string",
      "const": "../fixtures/v0.1/complete-paywall.json"
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/capability"
      }
    },
    "readerPolicy": {
      "$ref": "#/$defs/readerPolicy"
    },
    "normalizedOutcomes": {
      "$ref": "#/$defs/normalizedOutcomes"
    }
  },
  "$defs": {
    "capabilityName": {
      "type": "string",
      "enum": [
        "layout.scrollContainer",
        "layout.verticalStack",
        "component.text",
        "component.image",
        "component.featureList",
        "component.productSelector",
        "component.purchaseButton",
        "component.restoreButton",
        "component.closeButton",
        "component.legalText",
        "localization.catalogs",
        "localization.rtl",
        "product.references",
        "asset.bundledImage",
        "action.purchase",
        "action.restore",
        "action.close",
        "accessibility.metadata",
        "fallback.asset",
        "fallback.product",
        "outcome.normalized"
      ]
    },
    "capability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version",
        "fallback"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/capabilityName"
        },
        "version": {
          "type": "string",
          "const": "0.1"
        },
        "fallback": {
          "type": "string",
          "const": "rejectDocument"
        }
      }
    },
    "readerPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "unknownSchemaVersion",
        "unknownComponent",
        "unknownProperty",
        "unsupportedCapability",
        "invalidReference",
        "primaryDocumentRejected",
        "bundledFallbackRejected",
        "missingAsset",
        "unavailableProduct"
      ],
      "properties": {
        "unknownSchemaVersion": {
          "const": "rejectDocument"
        },
        "unknownComponent": {
          "const": "rejectDocument"
        },
        "unknownProperty": {
          "const": "rejectDocument"
        },
        "unsupportedCapability": {
          "const": "rejectDocument"
        },
        "invalidReference": {
          "const": "rejectDocument"
        },
        "primaryDocumentRejected": {
          "const": "loadBundledFallback"
        },
        "bundledFallbackRejected": {
          "const": "configurationUnavailable"
        },
        "missingAsset": {
          "const": "useDeclaredAssetFallback"
        },
        "unavailableProduct": {
          "const": "useSelectorFallback"
        }
      }
    },
    "normalizedOutcomes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "selectProduct",
        "purchase",
        "restore",
        "close",
        "presentation"
      ],
      "properties": {
        "selectProduct": {
          "const": [
            "productSelected"
          ]
        },
        "purchase": {
          "const": [
            "purchased",
            "alreadyEntitled",
            "cancelled",
            "productUnavailable",
            "purchaseFailed"
          ]
        },
        "restore": {
          "const": [
            "restored",
            "alreadyEntitled",
            "restoreNoPurchases",
            "restoreFailed"
          ]
        },
        "close": {
          "const": [
            "dismissed"
          ]
        },
        "presentation": {
          "const": [
            "purchased",
            "restored",
            "alreadyEntitled",
            "dismissed",
            "cancelled",
            "productUnavailable",
            "configurationUnavailable",
            "purchaseFailed",
            "renderingFailed"
          ]
        }
      }
    }
  }
}
