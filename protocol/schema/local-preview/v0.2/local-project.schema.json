{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mosaic:protocol:schema:local-preview:v0.2:local-project",
  "title": "Mosaic Local Project File 0.2",
  "description": "Local-only autosave container for one editable Mosaic paywall and deterministic preview state.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "fileFormatVersion",
    "editableDocumentId",
    "revision",
    "document",
    "preview",
    "mockCommerce"
  ],
  "properties": {
    "fileFormatVersion": {
      "const": "0.2"
    },
    "editableDocumentId": {
      "$ref": "urn:mosaic:protocol:schema:local-preview:v0.2:message#/$defs/editableDocumentId"
    },
    "revision": {
      "$ref": "urn:mosaic:protocol:schema:local-preview:v0.2:message#/$defs/localRevision"
    },
    "document": {
      "$ref": "urn:mosaic:protocol:schema:v0.2:paywall"
    },
    "preview": {
      "$ref": "urn:mosaic:protocol:schema:local-preview:v0.2:message#/$defs/previewContext"
    },
    "mockCommerce": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "revision",
        "state"
      ],
      "properties": {
        "revision": {
          "$ref": "urn:mosaic:protocol:schema:local-preview:v0.2:message#/$defs/localRevision"
        },
        "state": {
          "$ref": "urn:mosaic:protocol:schema:local-preview:v0.2:message#/$defs/mockCommerceState"
        }
      }
    }
  }
}
