{
  "schemaVersion": "0.1",
  "id": "minimal-paywall",
  "revision": 1,
  "compatibility": {
    "requiredCapabilities": [
      {
        "name": "layout.vertical",
        "version": "0.1"
      },
      {
        "name": "component.text",
        "version": "0.1"
      },
      {
        "name": "component.featureList",
        "version": "0.1"
      },
      {
        "name": "component.productSelector",
        "version": "0.1"
      },
      {
        "name": "component.purchaseButton",
        "version": "0.1"
      },
      {
        "name": "component.restoreButton",
        "version": "0.1"
      },
      {
        "name": "component.closeButton",
        "version": "0.1"
      },
      {
        "name": "component.legalText",
        "version": "0.1"
      }
    ]
  },
  "layout": {
    "type": "vertical",
    "id": "root-layout",
    "gap": 16,
    "padding": 24,
    "children": [
      {
        "type": "closeButton",
        "id": "close",
        "label": {
          "default": "Close",
          "localizationKey": "paywall.close"
        }
      },
      {
        "type": "text",
        "id": "headline",
        "value": {
          "default": "Unlock Mosaic Pro",
          "localizationKey": "paywall.headline"
        }
      },
      {
        "type": "featureList",
        "id": "features",
        "items": [
          {
            "id": "unlimited-projects",
            "text": {
              "default": "Unlimited projects",
              "localizationKey": "paywall.features.unlimited_projects"
            }
          },
          {
            "id": "priority-support",
            "text": {
              "default": "Priority support",
              "localizationKey": "paywall.features.priority_support"
            }
          }
        ]
      },
      {
        "type": "productSelector",
        "id": "plans",
        "products": [
          {
            "productId": "mosaic_pro_monthly"
          },
          {
            "productId": "mosaic_pro_yearly"
          }
        ],
        "initiallySelectedProductId": "mosaic_pro_yearly"
      },
      {
        "type": "purchaseButton",
        "id": "purchase",
        "label": {
          "default": "Continue",
          "localizationKey": "paywall.purchase"
        }
      },
      {
        "type": "restoreButton",
        "id": "restore",
        "label": {
          "default": "Restore purchases",
          "localizationKey": "paywall.restore"
        }
      },
      {
        "type": "legalText",
        "id": "legal",
        "value": {
          "default": "Subscription renews automatically until cancelled. Terms and privacy policy apply.",
          "localizationKey": "paywall.legal"
        }
      }
    ]
  }
}
